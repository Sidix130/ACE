from bs4 import BeautifulSoup, Tag
from typing import List, Dict, Any, Optional
import re
from collections import defaultdict

class TopologicalDetector:
    """
    Détecteur universel basé sur la topologie du DOM et le clustering structurel.
    Implémente la spécification V2 pour une détection agnostique aux plateformes.
    """
    def __init__(self, min_density: int = 3):
        self.min_density = min_density
        self.uuid_pattern = re.compile(r'__ACE_[A-Z]+_[a-f0-9]{8}__')

    def _text_density(self, tag: Tag) -> int:
        """Calcule le nombre de mots dans le tag."""
        return len(tag.get_text(strip=True).split())

    def _compute_signature(self, tag: Tag) -> str:
        """Génère une signature structurelle enrichie et normalisée."""
        name = tag.name
        
        # Classes CSS épurées (sans suffixes dynamiques)
        classes = tag.get('class', [])
        if isinstance(classes, str): classes = [classes]
        normalized_classes = []
        for c in classes:
            base = re.sub(r'[_-]?[a-f0-9]{6,}', '', c)
            base = re.sub(r'[_-]?\d{4,}', '', base)
            if base: normalized_classes.append(base)
        class_sig = '+'.join(sorted(normalized_classes))
        
        # Enfants directs par type
        child_counts = {}
        for child in tag.find_all(recursive=False):
            child_counts[child.name] = child_counts.get(child.name, 0) + 1
        children_sig = ','.join(f"{k}:{v}" for k,v in sorted(child_counts.items()))
        
        # Attributs sémantiques
        role = tag.get('role', '')
        testid = tag.get('data-testid', '')
        attr_sig = f"r={role};t={testid}" if role or testid else ""
        
        return f"{name}[{class_sig}]({children_sig}){attr_sig}"

    def _spacing_regularity_score(self, group: List[Tag]) -> float:
        """Calcule la régularité de l'espacement des nœuds au sein de leur parent."""
        if len(group) < 3: return 1.0
        
        parent = group[0].parent
        if not parent: return 0.1
        
        all_children = [c for c in parent.children if isinstance(c, Tag)]
        try:
            indices = [all_children.index(tag) for tag in group]
        except ValueError:
            return 0.1
            
        gaps = [indices[i+1] - indices[i] for i in range(len(indices)-1)]
        if not gaps: return 1.0
        
        mean_gap = sum(gaps) / len(gaps)
        variance = sum((g - mean_gap)**2 for g in gaps) / len(gaps)
        return 1.0 / (1.0 + variance)

    def _score_cluster(self, cluster: List[Tag]) -> float:
        """Score composite pour classer les clusters candidats."""
        n = len(cluster)
        if n == 0: return 0.0
        
        avg_density = sum(self._text_density(t) for t in cluster) / n
        regularity = self._spacing_regularity_score(cluster)
        
        # Signal de richesse de contenu (propres aux conversations LLM)
        richness = 1.0
        for t in cluster:
            if t.find(['pre', 'code', 'table', 'blockquote', 'h1', 'h2', 'h3', 'math']):
                richness += 0.5
        richness = min(richness, 3.0) # Cap à 3x
        
        # Signal UUID ACE (Preservation du Sanctuaire)
        uuid_bonus = 1.5 if any(self.uuid_pattern.search(t.get_text()) for t in cluster) else 1.0
            
        # Pénalité pour les patterns UI (Bannières, Modales, Pieds de page)
        ui_penalty = 1.0
        for t in cluster:
            # Recherche d'attributs suspects
            parent_attrs = str(t.parent.attrs).lower() if t.parent else ""
            self_attrs = str(t.attrs).lower() if t.attrs else ""
            if any(kw in self_attrs or kw in parent_attrs for kw in ['cookie', 'banner', 'dialog', 'modal', 'footer', 'nav', 'menu']):
                ui_penalty *= 0.5
                break # Une seule pénalité suffit
        
        # Score final : on favorise n > 1
        n_factor = n if n > 1 else 0.5
        
        return n_factor * avg_density * regularity * richness * uuid_bonus * ui_penalty

    def _are_signatures_compatible(self, sig1: str, sig2: str) -> bool:
        """Détermine si deux signatures sont assez proches pour appartenir au même cluster."""
        if sig1 == sig2: return True
        
        parts_re = re.compile(r'^(\w+)\[(.*?)\]\((.*?)\)(.*)$')
        m1 = parts_re.match(sig1)
        m2 = parts_re.match(sig2)
        
        if m1 and m2:
            # Même tag requis
            if m1.group(1) == m2.group(1):
                # Si même structure d'enfants, on vérifie un minimum de similarité de classes
                if m1.group(3) == m2.group(3):
                    c1 = set(m1.group(2).split('+')) if m1.group(2) else set()
                    c2 = set(m2.group(2).split('+')) if m2.group(2) else set()
                    # Si l'un a des classes et l'autre non, ou si classes totalement différentes : méfiance
                    if c1 and c2 and not (c1 & c2):
                        return False
                    return True
        return False

    def detect(self, soup: BeautifulSoup) -> List[Tag]:
        """Détecte les blocs de message via clustering topologique et analyse de flux."""
        # 0. Nettoyage : Exclure les éléments UI évidents (Bannières, Dialogues)
        for noise in soup.find_all(attrs={"role": ["dialog", "banner", "navigation"]}):
            noise.decompose()
        # On ne décompose pas tout le body, juste les overlays probables
        for noise in soup.find_all(class_=re.compile(r'cookie|modal|overlay|popup', re.I)):
            if noise.name != 'body':
                noise.decompose()

        # 1. Identifier tous les candidats par densité (Tous les tags sont permis si denses)
        candidates = []
        for tag in soup.find_all(True): # True pour tous les tags
            if tag.name in ['html', 'body', 'script', 'style', 'head']: continue
            if self._text_density(tag) >= self.min_density or self.uuid_pattern.search(tag.get_text()):
                candidates.append(tag)
        
        if not candidates: return []
        
        # 2. Clustering par signature et parent (Gestion des "Box" chats)
        clusters = []
        for cand in candidates:
            added = False
            sig = self._compute_signature(cand)
            for cluster in clusters:
                if cluster[0].parent == cand.parent and self._are_signatures_compatible(self._compute_signature(cluster[0]), sig):
                    cluster.append(cand)
                    added = True
                    break
            if not added:
                clusters.append([cand])
        
        # 2b. AJOUT : Gestion des "Stream" chats (Grok)
        # Si un parent contient des <hr> séparant des candidats, c'est un signal très fort
        for parent in set(c.parent for c in candidates if c.parent):
            hr_count = len(parent.find_all('hr', recursive=False))
            if hr_count >= 1:
                # On regroupe les enfants significatifs du parent comme un cluster
                stream_cluster = [c for c in parent.find_all(recursive=False) if (c in candidates or c.name in ['h3', 'blockquote'])]
                if len(stream_cluster) > 2:
                    clusters.append(stream_cluster)

        if not clusters: return []
        
        # 3. Élimination des clusters redondants
        final_clusters = []
        for c1 in clusters:
            is_redundant = False
            for c2 in clusters:
                if c1 is c2: continue
                # Si c1 est contenu dans c2
                if all(any(node is ancestor or node in getattr(ancestor, 'descendants', []) for ancestor in c2) for node in c1):
                    # RÈGLE DE GRANULARITÉ : 
                    # Si c1 (le contenu plus profond) a autant ou plus d'éléments (n) que c2
                    # ET que c1 n'est pas juste un wrapper unique
                    if len(c1) >= len(c2) and len(c1) > 1:
                        # On garde la granularité
                        continue
                    else:
                        if self._score_cluster(c2) >= self._score_cluster(c1):
                            is_redundant = True
                            break
            if not is_redundant:
                final_clusters.append(c1)
        
        if not final_clusters: return []
        
        # 4. Sélection du meilleur cluster
        best_cluster = max(final_clusters, key=self._score_cluster)
        
        # 5. Ordonnancement chronologique
        return sorted(best_cluster, key=lambda t: t.sourceline or 0)
